generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Raw request/response logs ───────────────────────────────────────────────

/// Stores every raw JSON request/response to/from FlyGate
/// type: 1 = request, 2 = response
model FlyGateReqRes {
  auto      Int      @id @default(autoincrement())
  orderId   String?  @map("OrderId") @db.VarChar(20)
  type      Int
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamp
  data      Json     @map("Data")

  @@map("FlyGateReqRes")
}

/// Stores every raw XML request/response to/from CBS
/// type: 1 = request, 2 = response
model CbsReqRes {
  auto      Int      @id @default(autoincrement())
  orderId   String?  @map("OrderId") @db.VarChar(20)
  type      Int
  createdAt DateTime @default(now()) @map("CreatedAt") @db.Timestamp
  data      String   @map("Data") @db.Text

  @@map("CbsReqRes")
}

// ─── FlyGate audit / pending ─────────────────────────────────────────────────

/// Audit log for every FlyGate interaction step.
/// Also used as the pending-order store during validatePNR.
/// reqType: 1=CBS req, 2=CBS resp, 3=FlyGate confirm resp, 4=refund
model FLYGATEDetails {
  auto            BigInt   @id @default(autoincrement())
  orderId         String   @db.VarChar(20)
  reqType         Int
  respCode        String   @map("RESPCODE") @db.VarChar(10)
  respResult      String   @map("RESPRESULT") @db.Text
  amount          Decimal  @map("AMOUNT") @db.Money
  traceNumber     String   @db.VarChar(50)
  orderStatusCode Int
  resultDesc      String   @db.VarChar(100)
  cbsRefNo        String   @map("CBSRefNo") @db.VarChar(50)
  isRefund        Int      @db.SmallInt
  // Extra fields from validatePNR / GetOrder response
  customerName    String?  @map("CustomerName") @db.VarChar(500)
  pnr             String?  @map("PNR") @db.VarChar(25)
  currency        String?  @map("Currency") @db.VarChar(5)
  entryDate       DateTime @default(now()) @db.Timestamp

  @@map("FLYGATEDetails")
}

// ─── Confirmed transactions ───────────────────────────────────────────────────

/// Full record written after a successful FlyGate ConfirmOrder
model FlygateTransactions {
  code     Int      @id @default(autoincrement()) @map("CODE")
  orderId  String?  @map("OrderId") @db.VarChar(20)
  trnDate  DateTime @default(now()) @map("TrnDate") @db.Timestamp

  // Account details
  drAcNo String? @map("DrAcNO") @db.VarChar(50)
  crAcNo String? @map("CrAcNO") @db.VarChar(50)

  // Customer info
  customerName String? @map("CUSTOMERNAME") @db.VarChar(500)
  firstName    String? @map("FIRSTNAME") @db.VarChar(200)
  lastName     String? @map("LASTNAME") @db.VarChar(200)
  mobileNo     String? @map("MOBILENO") @db.VarChar(50)

  // Flight & payment
  pnr           String?  @map("PNR") @db.VarChar(25)
  amount        Decimal? @map("Amount") @db.Money
  currency      String?  @map("Currency") @db.VarChar(5)
  remarks       String?  @map("Remarks") @db.VarChar(500)
  status        Decimal? @map("STATUS") @db.Decimal
  traceNumber   String?  @map("TraceNumber") @db.VarChar(150)
  batchId       String?  @map("BatchId") @db.VarChar(150)
  bankRefNo     String?  @map("BankRefNo") @db.VarChar(500)
  processedDate DateTime @default(now()) @map("ProcessedDate") @db.Timestamp
  channel       String?  @map("Channel") @db.VarChar(20)
  utilRefNo     String?  @map("UtilRefNo") @db.VarChar(50)

  // CBS fault info
  faultCode   Decimal? @map("FAULTCODE") @db.Decimal
  faultString String?  @map("FAULTSTRING") @db.Text

  // Refund fields
  isRefund            Int?    @map("IsRefund") @db.SmallInt
  refundStatus        Int?    @map("RefundStatus") @db.SmallInt
  refundReferenceCode String? @map("RefundReferenceCode") @db.VarChar(250)
  orgPnr              String? @map("OrgPNR") @db.VarChar(25)
  orgBankRefNo        String? @map("OrgBankRefNo") @db.VarChar(500)

  // Auto-reversal (triggered when FlyGate confirm fails after CBS success)
  autoReversed      Int?     @default(0) @map("AutoReversed") @db.SmallInt  // 1=reversed, 0=not
  autoReversalRef   String?  @map("AutoReversalRef") @db.VarChar(50)        // CBS reversal FCCREF
  autoReversalError String?  @map("AutoReversalError") @db.VarChar(500)     // if reversal itself failed

  entryDate DateTime @default(now()) @map("EntryDate") @db.Timestamp

  @@map("FlygateTransactions")
}

// ─── General transaction journal ─────────────────────────────────────────────

/// CBS-side transaction journal entry written on successful payment
model Transactions {
  auto          Int      @id @default(autoincrement()) @map("Auto")
  orderId       String?  @map("OrderId") @db.VarChar(20)
  pnr           String?  @map("PNR") @db.VarChar(25)
  trnDate       DateTime @default(now()) @map("TrnDate") @db.Timestamp
  processedTime DateTime @default(now()) @map("ProcessedTime") @db.Timestamp

  // Accounts
  drAcNo   String? @map("DrAcNo") @db.VarChar(50)
  crAcNo   String? @map("CrAcNo") @db.VarChar(50)
  branchCode String? @map("BranchCode") @db.VarChar(10)

  // Amount
  amount       Decimal? @map("Amount") @db.Money
  currencyCode String?  @map("CurrencyCode") @db.VarChar(5)

  // Customer
  customerName String? @map("CustomerName") @db.VarChar(500)
  custIden     String? @map("CustIden") @db.VarChar(50)

  // References
  cbsRefNo    String? @map("CBSRefNo") @db.VarChar(50)
  traceNumber String? @map("TraceNumber") @db.VarChar(150)
  batchId     String? @map("BatchId") @db.VarChar(50)
  scrollId    String? @map("ScrollId") @db.VarChar(50)
  utilRefNo   String? @map("UtilRefNo") @db.VarChar(100)
  uniqueId    String? @unique @map("UniqueId") @db.VarChar(50)

  // Meta
  crDr        String?  @map("CrDr") @db.VarChar(6)
  remarks     String?  @map("Remarks") @db.VarChar(500)
  particulars String?  @map("Particulars") @db.VarChar(500)
  status      Int?     @map("Status") @db.SmallInt
  channel     String?  @map("Channel") @db.VarChar(10)
  subChannel  String?  @map("SubChannel") @db.VarChar(10)

  // CBS fault
  faultCode   Decimal? @map("FAULTCODE") @db.Decimal
  faultString String?  @map("FAULTSTRING") @db.Text

  // Auto-reversal (triggered when confirm fails after CBS success)
  autoReversed      Int?    @default(0) @map("AutoReversed") @db.SmallInt
  autoReversalRef   String? @map("AutoReversalRef") @db.VarChar(50)
  autoReversalError String? @map("AutoReversalError") @db.VarChar(500)

  entryTime DateTime @default(now()) @map("EntryTime") @db.Timestamp

  @@map("Transactions")
}

// ─── Refund ledger ────────────────────────────────────────────────────────────

// ─── Generic CBS transfer log ─────────────────────────────────────────────────

/// Audit log for every generic CBS CreateTransaction call
/// channel: TELEBIRR | AIRLINE | BILL | MPESA | OTHER
model CbsTransfer {
  id            Int      @id @default(autoincrement())
  channel       String   @map("Channel") @db.VarChar(30)
  prd           String   @map("PRD") @db.VarChar(20)
  drAcNo        String   @map("DrAcNo") @db.VarChar(50)
  crAcNo        String   @map("CrAcNo") @db.VarChar(50)
  drBranch      String?  @map("DrBranch") @db.VarChar(10)
  crBranch      String?  @map("CrBranch") @db.VarChar(10)
  amount        Decimal  @map("Amount") @db.Money
  currency      String   @default("ETB") @map("Currency") @db.VarChar(5)
  narrative     String?  @map("Narrative") @db.VarChar(500)
  referenceId   String?  @map("ReferenceId") @db.VarChar(100)  // caller's own ref (PNR, bill no, phone…)
  traceNumber   String   @map("TraceNumber") @db.VarChar(150)
  cbsRefNo      String?  @map("CBSRefNo") @db.VarChar(50)      // FCCREF from CBS on success
  status        Int      @map("Status") @db.SmallInt            // 1=success, 0=failed
  errorCode     String?  @map("ErrorCode") @db.VarChar(50)
  errorDesc     String?  @map("ErrorDesc") @db.VarChar(500)
  requestXml    String?  @map("RequestXml") @db.Text
  responseXml   String?  @map("ResponseXml") @db.Text
  entryTime     DateTime @default(now()) @map("EntryTime") @db.Timestamp

  @@map("CbsTransfer")
}

// ─── Ride bill payment ────────────────────────────────────────────────────────

/// Ride bill query + payment audit log
model RideTransaction {
  id                Int      @id @default(autoincrement())
  phone             String   @map("Phone") @db.VarChar(20)
  fullName          String?  @map("FullName") @db.VarChar(200)
  accountStatus     String?  @map("AccountStatus") @db.VarChar(20)  // active, inactive
  amount            Decimal? @map("Amount") @db.Money
  billRefNo         String?  @map("BillRefNo") @db.VarChar(100)     // CBS FCCREF
  transTime         String?  @map("TransTime") @db.VarChar(20)      // YYYYMMDDHHmmss
  remark            String?  @map("Remark") @db.VarChar(500)
  acknowledgementId String?  @map("AcknowledgementId") @db.VarChar(100)  // from Ride confirm response
  
  // CBS transfer details
  cbsRefNo          String?  @map("CBSRefNo") @db.VarChar(50)
  traceNumber       String?  @map("TraceNumber") @db.VarChar(150)
  drAcNo            String?  @map("DrAcNo") @db.VarChar(50)
  crAcNo            String?  @map("CrAcNo") @db.VarChar(50)
  
  // Status tracking
  queryStatus       Int      @default(0) @map("QueryStatus") @db.SmallInt
  paymentStatus     Int      @default(0) @map("PaymentStatus") @db.SmallInt
  cbsStatus         Int      @default(0) @map("CBSStatus") @db.SmallInt

  // Auto-reversal (triggered when Ride confirm fails after CBS success)
  autoReversed      Int?    @default(0) @map("AutoReversed") @db.SmallInt
  autoReversalRef   String? @map("AutoReversalRef") @db.VarChar(50)
  autoReversalError String? @map("AutoReversalError") @db.VarChar(500)

  errorDesc         String?  @map("ErrorDesc") @db.VarChar(500)
  queryResponse     String?  @map("QueryResponse") @db.Text     // raw JSON from Ride query
  confirmResponse   String?  @map("ConfirmResponse") @db.Text   // raw JSON from Ride confirm
  
  entryTime         DateTime @default(now()) @map("EntryTime") @db.Timestamp

  @@map("RideTransaction")
}

model RefundDetails {
  auto        Int      @id @default(autoincrement()) @map("Auto")
  receiveDate DateTime @default(now()) @map("ReceiveDate") @db.Timestamp
  shortCode   String?  @map("ShortCode") @db.VarChar(10)
  orderId     String?  @map("OrderId") @db.VarChar(20)
  amount      Decimal? @map("Amount") @db.Money

  cbsRefNumber  String? @map("CBSRefNumber") @db.VarChar(50)
  flyRefundCode String? @map("FLYRefundCode") @db.VarChar(30)

  acknowledgeStatus Int?    @map("AcknowledgeStatus") @db.SmallInt
  acknowledgDesc    String? @map("AcknowledgDesc") @db.VarChar(50)

  refundStatus Int?      @map("RefundStatus") @db.SmallInt
  refundCbsRef String?   @map("RefundCBSRef") @db.VarChar(50)
  refundDate   DateTime? @map("RefundDate") @db.Timestamp
  refundDesc   String?   @map("RefundDesc") @db.VarChar(100)

  confirmRefundStatus Int?      @map("ConfirmRefundStatus") @db.SmallInt
  confirmRefundDate   DateTime? @map("ConfirmRefundDate") @db.Timestamp
  status              Int?      @map("status") @db.SmallInt

  @@map("RefundLedger")
}
